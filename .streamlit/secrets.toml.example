# ════════════════════════════════════════════════════════════════════
# نموذج إعدادات الأسرار — انسخه إلى .streamlit/secrets.toml واملأ القيم.
# لا ترفع secrets.toml إلى GitHub (مُستثنى في .gitignore).
# ════════════════════════════════════════════════════════════════════

# 🔐 تسجيل الدخول (السكرتير/المالك)
[auth]
username = "admin"
password = "ضع_كلمة_مرور_قوية"

# 📊 ملف Google Sheets (الملف الجديد)
[sheet]
id = "1U5h-2Z6_Qt_RvdGN7mw-rArDt_dfbRojdUyu-jXeDmY"

# 🔗 روابط نماذج Google (اختياري — لمشاركتها مع المعلمين وأولياء الأمور)
[forms]
parent  = "https://forms.gle/PUT_PARENT_FORM_LINK"
teacher = "https://forms.gle/PUT_TEACHER_FORM_LINK"

# ✍️ الكتابة المجانية عبر Google Apps Script (لا تحتاج حساب خدمة ولا بطاقة)
# انشر apps_script/Code.gs داخل الورقة كـ Web app، وضع رابط /exec ونفس الرمز هنا.
# (استخدم هذا القسم بدلًا من [gcp_service_account] إن أردت الطريقة المجانية.)
[apps_script]
url   = "https://script.google.com/macros/s/XXXXX/exec"
token = "change-this-secret-token"

# 🔑 حساب خدمة Google (لتفعيل الحفظ المباشر) — من ملف JSON
# انسخ كل الحقول من ملف مفتاح حساب الخدمة هنا:
[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "dar-bot@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
